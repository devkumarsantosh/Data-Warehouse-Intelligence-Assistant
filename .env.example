# Copy to .env and fill in real values. Never commit the real .env.

CDWIA_CLASSIFIER_CONFIDENCE_THRESHOLD=0.75
CDWIA_PLANNER_MODEL=claude-haiku-4-5-20251001
CDWIA_ENABLE_LLM_FALLBACK=true

CDWIA_SQL_ROW_LIMIT_DEFAULT=10000
CDWIA_SQL_COST_THRESHOLD=5000.0
CDWIA_SQL_ALLOWLIST_PATH=config/sql_allowlist.yaml
CDWIA_SQL_TIMEOUT_MS=15000

CDWIA_VECTOR_TOP_K=20
CDWIA_BM25_TOP_K=20
CDWIA_RERANK_TOP_K=6

CDWIA_REDIS_URL=redis://localhost:6379/0
CDWIA_POSTGRES_DSN=postgresql://cdwia_ro:changeme@localhost:5432/warehouse
CDWIA_PINECONE_INDEX=cdwia-docs
CDWIA_KAFKA_BOOTSTRAP=localhost:9092
CDWIA_OPA_URL=http://localhost:8181/v1/data/cdwia/allow

CDWIA_ENABLE_PII_OUTBOUND_SCAN=true

# Provider credentials — populate from your secrets manager in real
# deployments (AWS Secrets Manager / HashiCorp Vault), never hardcode.
ANTHROPIC_API_KEY=
PINECONE_API_KEY=
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
